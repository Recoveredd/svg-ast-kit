{
  "name": "svg-ast-kit",
  "version": "0.1.1",
  "description": "Parse SVG strings into typed JSON trees with readable errors.",
  "type": "module",
  "sideEffects": false,
  "license": "MPL-2.0",
  "author": "Recoveredd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Recoveredd/svg-ast-kit.git"
  },
  "bugs": {
    "url": "https://github.com/Recoveredd/svg-ast-kit/issues"
  },
  "homepage": "https://github.com/Recoveredd/svg-ast-kit#readme",
  "keywords": [
    "svg",
    "ast",
    "parser",
    "json",
    "xml",
    "typescript",
    "browser"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
